# Example secrets.yaml for definitely-not-crosswords local development.
# Use SOPS to encrypt this file:
#   sops secrets.yaml
#
# Once encrypted, sops-nix inside the devShell will decrypt these.

KEYCLOAK_CLIENT_SECRET: "supersecretcrosswords"
NEXTAUTH_SECRET: "supersecretsecret"
DATABASE_URL: "postgresql://postgres:postgres@localhost:5432/postgres"

# E2E demo/canary test users (e2e/tests/demo.spec.ts logs in with these;
# seed_test_users creates/updates them — believable names, 32-char passwords).
E2E_EMAIL: "riley.calloway@example.com"
E2E_PASSWORD: "change-me-32-chars"
E2E_EMAIL_2: "maya.okafor@example.com"
E2E_PASSWORD_2: "change-me-32-chars"
# Same users as seed input — keep in sync with the keys above. The optional
# team is created (first user owns it, everyone joins) so the teammate-scoped
# stats compare panel lights up in the demo.
E2E_USERS_JSON: '{"team":{"name":"Thursday Puzzlers"},"users":[{"email":"riley.calloway@example.com","name":"Riley Calloway","password":"change-me-32-chars"},{"email":"maya.okafor@example.com","name":"Maya Okafor","password":"change-me-32-chars"}]}'

# Lemon Squeezy (monetization) — the Rust server reads these unprefixed
# (LEMONSQUEEZY_*); the NUXT_* names are kept for the legacy stack.
LEMONSQUEEZY_API_KEY: ""
LEMONSQUEEZY_STORE_ID: ""
LEMONSQUEEZY_VARIANT_ID: ""
LEMONSQUEEZY_WEBHOOK_SECRET: ""
