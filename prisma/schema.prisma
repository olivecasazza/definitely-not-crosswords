// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  // NOTE: You probably want to change this to another database later on
  provider = "postgresql"

  // This value is read from the .env file.
  url = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  role          UserRole     @default(USER)
  accounts      Account[]
  sessions      Session[]
  gameMember    GameMember[]
  GameAction    GameAction[]
  generatedJobs CrosswordGenerationJob[]

  UserSprite UserSprite?
}

model UserSprite {
  id     String @id @default(cuid())
  blob   Bytes

  User   User   @relation(fields: [userId], references: [id])
  userId String @unique
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum QuestionDirectionEnum {
  DOWN
  ACROSS
}

enum UserRole {
  USER
  ADMIN
}

enum GameSource {
  MANUAL
  SCRAPED
  GENERATED
}

enum GenerationStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum DictionarySource {
  WORDNET
}

enum DictionaryPartOfSpeech {
  NOUN
  VERB
  ADJECTIVE
  ADVERB
}

model Question {
  id           String                @id @default(uuid())
  type         String                @default("Question")
  number       Int
  answer       String
  questionText String
  rootX        Int
  rootY        Int
  direction    QuestionDirectionEnum @default(DOWN)
  gameId       String
  game         Game                  @relation(fields: [gameId], references: [id], onDelete: Cascade)
}

model Game {
  id        String          @id @default(uuid())
  type      String          @default("Game")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  title     String
  published Boolean         @default(false)
  source    GameSource      @default(MANUAL)
  active    ActiveGame[]
  completed CompletedGame[]
  questions Question[]
  generatorJob CrosswordGenerationJob?
}

model CrosswordGenerationJob {
  id            String           @id @default(uuid())
  status        GenerationStatus @default(QUEUED)
  topic         String
  width         Int
  height        Int
  minWordLength Int
  maxWordLength Int
  params        Json
  metrics       Json?
  error         String?          @db.Text
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  createdById   String
  createdBy     User             @relation(fields: [createdById], references: [id])
  resultGameId  String?          @unique
  resultGame    Game?            @relation(fields: [resultGameId], references: [id])

  @@index([status, createdAt])
  @@index([createdById, createdAt])
}

model DictionaryWord {
  id          String                 @id @default(uuid())
  word        String                 @unique
  length      Int
  source      DictionarySource       @default(WORDNET)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  definitions DictionaryDefinition[]

  @@index([length])
  @@index([source, length])
}

model DictionaryDefinition {
  id           String                 @id @default(uuid())
  wordId       String
  word         DictionaryWord         @relation(fields: [wordId], references: [id], onDelete: Cascade)
  partOfSpeech DictionaryPartOfSpeech
  synsetOffset String
  lemma        String
  gloss        String                 @db.Text
  examples     Json?
  source       DictionarySource       @default(WORDNET)
  createdAt    DateTime               @default(now())

  @@unique([wordId, partOfSpeech, synsetOffset])
  @@index([partOfSpeech])
}

model ActiveGame {
  id          String       @id @default(uuid())
  type        String       @default("ActiveGame")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  actions     GameAction[]
  gameId      String
  game        Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameMembers GameMember[]
}

model GameAction {
  id            String             @id @default(uuid())
  type          String             @default("GameActions")
  submittedAt   DateTime           @default(now())
  activeGameId  String
  activeGame    ActiveGame         @relation(fields: [activeGameId], references: [id], onDelete: Cascade)
  actionType    GameActionTypeEnum
  submittedBy   User               @relation(fields: [userId], references: [id])
  cordX         Int
  cordY         Int
  previousState String
  state         String
  userId        String
}

enum GameActionTypeEnum {
  correctGuess
  incorrectGuess
  placeholder
}

model CompletedGame {
  id          String       @id @default(uuid())
  type        String       @default("CompletedGame")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  gameId      String
  game        Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameStatsId String
  gameStats   GameStats    @relation(fields: [gameStatsId], references: [id])
  gameMembers GameMember[]
}

model GameStats {
  id            String          @id @default(uuid())
  type          String          @default("GameStats")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  memberScores  MemberScore[]
  completedGame CompletedGame[]
}

model GameMember {
  id              String         @id @default(uuid())
  type            String         @default("GameMember")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  isOwner         Boolean        @default(false)
  activeGameId    String?
  activeGame      ActiveGame?    @relation(fields: [activeGameId], references: [id], onDelete: Cascade)
  completedGameId String?
  completedGame   CompletedGame? @relation(fields: [completedGameId], references: [id], onDelete: Cascade)
  memberScore     MemberScore[]
}

model MemberScore {
  id          String     @id @default(uuid())
  type        String     @default("MemberScore")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  memberId    String
  member      GameMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  gameStatsId String?
  gameStats   GameStats? @relation(fields: [gameStatsId], references: [id], onDelete: Cascade)
  score       Int        @default(0)
}
